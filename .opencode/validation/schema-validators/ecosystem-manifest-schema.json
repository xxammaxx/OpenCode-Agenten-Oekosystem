{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ecosystem Manifest Schema",
  "type": "object",
  "required": ["version", "schema_version", "name", "catalogs", "detectors"],
  "properties": {
    "version": { "type": "string" },
    "schema_version": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "bootstrap": { "type": "object" },
    "supported_runtimes": { "type": "object" },
    "supported_os": {
      "type": "array",
      "items": { "type": "string" }
    },
    "os_constraints": { "type": "object" },
    "environment_variables": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trust_tiers": { "type": "object" },
    "tool_filter": { "type": "object" },
    "activation_rules": { "type": "object" },
    "detectors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "catalogs": { "type": "object" },
    "conflict_strategy": { "type": "object" },
    "install_targets": { "type": "object" },
    "remote_ci": { "type": "object" }
  }
}
